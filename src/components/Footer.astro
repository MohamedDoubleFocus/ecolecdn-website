---
import { getEntry } from 'astro:content';
import Logo from './Logo.astro';

const contact = await getEntry('contact', 'info');
const c = contact!.data;
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="container-page py-16 grid gap-12 md:grid-cols-3 lg:grid-cols-4">
    <div class="lg:col-span-2 space-y-4">
      <div class="bg-white inline-block rounded-md p-2">
        <Logo />
      </div>
      <p class="text-white/80 max-w-md leading-relaxed mt-4">
        École de conduite à Côte-des-Neiges, Montréal. Formation PESR Classe 5,
        cours de perfectionnement et location de véhicule pour examen SAAQ.
      </p>
      {c.social_links.length > 0 && (
        <div class="flex gap-3 pt-2">
          {c.social_links.map((s: { label: string; url: string }) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 inline-flex items-center justify-center rounded-full bg-white/10 hover:bg-accent transition-colors"
              aria-label={`Suivez-nous sur ${s.label}`}
            >
              <span class="text-sm font-semibold">{s.label.charAt(0)}</span>
            </a>
          ))}
        </div>
      )}
    </div>

    <div>
      <h3 class="text-white font-display font-semibold text-lg mb-4">Navigation</h3>
      <ul class="space-y-2 text-white/80">
        <li><a href="/" class="hover:text-accent transition-colors">Accueil</a></li>
        <li><a href="/cours" class="hover:text-accent transition-colors">Cours</a></li>
        <li><a href="/location" class="hover:text-accent transition-colors">Location</a></li>
        <li><a href="/faq" class="hover:text-accent transition-colors">FAQ</a></li>
        <li><a href="/inscription" class="hover:text-accent transition-colors">Inscription</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-white font-display font-semibold text-lg mb-4">Contact</h3>
      <ul class="space-y-3 text-white/80 text-sm">
        <li>
          <a href={`tel:${c.phone_link}`} class="hover:text-accent transition-colors flex items-start gap-2">
            <span aria-hidden="true">📞</span> {c.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${c.email}`} class="hover:text-accent transition-colors flex items-start gap-2 break-all">
            <span aria-hidden="true">✉️</span> {c.email}
          </a>
        </li>
        <li class="flex items-start gap-2">
          <span aria-hidden="true">📍</span>
          <span>{c.address_line}<br/>{c.address_city}, {c.address_region} {c.address_postal}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-page py-6 flex flex-col md:flex-row gap-2 justify-between items-center text-sm text-white/60">
      <p>© {year} École de conduite Côte-des-Neiges. Tous droits réservés.</p>
      <p>Conçu avec soin à Montréal</p>
    </div>
  </div>
</footer>
