---
import { getEntry } from 'astro:content';

const contact = await getEntry('contact', 'info');
const c = contact!.data;
---

<section class="bg-sky-soft py-20 md:py-section" id="contact">
  <div class="container-page">
    <div class="max-w-2xl mb-14" data-anim="up">
      <p class="eyebrow">Nous joindre</p>
      <h2 class="text-h2">Contact et heures d'ouverture</h2>
      <p class="text-lead text-ink-soft mt-4">
        Une question? Une réservation? Visitez-nous à Côte-des-Neiges ou contactez-nous
        par téléphone, par courriel, ou via les liens ci-dessous.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10">
      <!-- Coordonnées + horaires -->
      <div class="space-y-8">
        <div class="card-soft p-7 space-y-4" data-anim="up">
          <div>
            <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-1">Adresse</p>
            <p class="text-navy font-semibold">{c.address_line}</p>
            <p class="text-ink">{c.address_city}, {c.address_region} {c.address_postal}</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-4 pt-4 border-t border-slate-100">
            <div>
              <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-1">Téléphone</p>
              <a href={`tel:${c.phone_link}`} class="text-navy font-semibold hover:text-accent transition-colors">
                {c.phone}
              </a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-1">Courriel</p>
              <a href={`mailto:${c.email}`} class="text-navy font-semibold hover:text-accent transition-colors break-all text-sm">
                {c.email}
              </a>
            </div>
          </div>
        </div>

        <div class="card-soft p-7" data-anim="up">
          <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-3">Heures — Accueil</p>
          <table class="w-full text-sm">
            <tbody>
              {c.hours_office.map((h: { day: string; hours: string }) => (
                <tr class="border-b border-slate-100 last:border-0">
                  <th scope="row" class="py-2 text-left font-medium text-navy">{h.day}</th>
                  <td class="py-2 text-right text-ink">{h.hours}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="card-soft p-7" data-anim="up">
          <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-3">
            Heures — Cours pratiques et théoriques
          </p>
          <table class="w-full text-sm">
            <tbody>
              {c.hours_courses.map((h: { day: string; hours: string }) => (
                <tr class="border-b border-slate-100 last:border-0">
                  <th scope="row" class="py-2 text-left font-medium text-navy">{h.day}</th>
                  <td class="py-2 text-right text-ink">{h.hours}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Carte Google Maps -->
      <div class="card-soft overflow-hidden p-0 min-h-[500px] lg:sticky lg:top-28 lg:self-start" data-anim="up">
        <iframe
          src={c.google_maps_embed_url}
          class="w-full h-full min-h-[500px] border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Localisation sur Google Maps : 5641 Chemin de la Côte-des-Neiges, Montréal"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>
