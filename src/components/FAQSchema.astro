---
export interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
