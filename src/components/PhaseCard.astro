---
export interface Props {
  number: number;
  title: string;
  theory: string;
  practice?: string;
  duration: string;
}
const { number, title, theory, practice, duration } = Astro.props;
---

<article class="card-soft p-7 md:p-8 flex flex-col gap-4 h-full" data-anim="up">
  <div class="flex items-center gap-4 mb-1">
    <span class="w-12 h-12 rounded-full bg-accent text-white font-display font-bold text-xl flex items-center justify-center shadow-cta flex-shrink-0">
      {number}
    </span>
    <div class="flex-1">
      <p class="text-xs uppercase tracking-widest text-ink-soft font-medium">Phase {number}</p>
      <h3 class="text-h3 text-navy leading-tight">{title}</h3>
    </div>
  </div>

  <div class="space-y-3 mt-2">
    <div>
      <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-1">Théorie</p>
      <p class="text-ink leading-relaxed text-sm">{theory}</p>
    </div>

    {practice && (
      <div>
        <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-1">Pratique</p>
        <p class="text-ink leading-relaxed text-sm">{practice}</p>
      </div>
    )}
  </div>

  <div class="mt-auto pt-4 border-t border-slate-100">
    <p class="text-xs uppercase tracking-widest text-ink-soft mb-1">Durée</p>
    <p class="text-navy font-semibold text-sm">{duration}</p>
  </div>
</article>
