---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ContactSection from '../components/ContactSection.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { inlineMd } from '../lib/markdown';

const page = await getEntry('pages', 'accueil');
const data = page!.data;

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={data.title} description={data.meta_description} keywords={data.meta_keywords}>
  <slot name="head" slot="head">
    <LocalBusinessSchema />
  </slot>

  <Hero
    title={data.hero_title!}
    subtitle={data.hero_subtitle}
    image={data.hero_image!}
    imageAlt="Vue conducteur sur une route à l'horizon — perspective d'apprentissage de la conduite."
    ctaLabel={data.cta_label}
    ctaHref={data.cta_href}
    secondaryLabel="Nous joindre"
    secondaryHref="#contact"
  />

  <!-- Section "École de conduite experte" -->
  <section class="py-20 md:py-section">
    <div class="container-page grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div data-anim="up">
        {data.about_eyebrow && <p class="eyebrow">{data.about_eyebrow}</p>}
        {data.about_title && <h2 class="text-h2 mb-6">{data.about_title}</h2>}
        <div class="space-y-5 text-ink leading-relaxed text-lg max-w-prose">
          {data.about_paragraph_1 && <p set:html={inlineMd(data.about_paragraph_1)} />}
          {data.about_paragraph_2 && <p set:html={inlineMd(data.about_paragraph_2)} />}
          {data.about_paragraph_3 && <p set:html={inlineMd(data.about_paragraph_3)} />}
        </div>
        {data.about_stats && data.about_stats.length > 0 && (
          <div class="grid grid-cols-3 gap-6 mt-10 pt-8 border-t border-slate-100">
            {data.about_stats.map((s: { value: string; label: string }) => (
              <div>
                <p class="font-display text-3xl font-bold text-accent">{s.value}</p>
                <p class="text-sm text-ink-soft mt-1">{s.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>
      {data.about_image && (
        <div class="relative" data-anim="up">
          <img
            src={data.about_image}
            alt={data.about_image_alt ?? ''}
            class="w-full h-auto rounded-card shadow-lift object-cover aspect-[4/5]"
            loading="lazy"
            decoding="async"
          />
          {(data.about_badge_title || data.about_badge_subtitle) && (
            <div class="absolute -bottom-6 -left-6 bg-white rounded-card shadow-soft p-5 hidden md:block">
              {data.about_badge_title && <p class="font-display font-semibold text-navy">{data.about_badge_title}</p>}
              {data.about_badge_subtitle && <p class="text-xs text-ink-soft">{data.about_badge_subtitle}</p>}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- Section "Flexibilité et proximité" -->
  <section class="py-20 md:py-section bg-sky-soft">
    <div class="container-page grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="lg:order-2" data-anim="up">
        {data.proximity_eyebrow && <p class="eyebrow">{data.proximity_eyebrow}</p>}
        {data.proximity_title && <h2 class="text-h2 mb-6">{data.proximity_title}</h2>}
        <div class="space-y-5 text-ink leading-relaxed text-lg max-w-prose">
          {data.proximity_paragraph_1 && <p set:html={inlineMd(data.proximity_paragraph_1)} />}
          {data.proximity_paragraph_2 && <p set:html={inlineMd(data.proximity_paragraph_2)} />}
          {data.proximity_paragraph_3 && <p set:html={inlineMd(data.proximity_paragraph_3)} />}
        </div>
        {data.proximity_button_label && data.proximity_button_href && (
          <a href={data.proximity_button_href} class="btn-secondary mt-8">{data.proximity_button_label}</a>
        )}
      </div>
      {data.proximity_image && (
        <div class="lg:order-1" data-anim="up">
          <img
            src={data.proximity_image}
            alt={data.proximity_image_alt ?? ''}
            class="w-full h-auto rounded-card shadow-lift object-cover aspect-[4/5]"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}
    </div>
  </section>

  <!-- Cours et tarifs -->
  <section class="py-20 md:py-section">
    <div class="container-page">
      <div class="max-w-2xl mb-14" data-anim="up">
        {data.courses_section_eyebrow && <p class="eyebrow">{data.courses_section_eyebrow}</p>}
        {data.courses_section_title && <h2 class="text-h2">{data.courses_section_title}</h2>}
        {data.courses_section_intro && <p class="text-lead text-ink-soft mt-4">{data.courses_section_intro}</p>}
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        {courses.map((course, idx) => (
          <CourseCard
            title={course.data.title}
            price={course.data.price}
            priceUnit={course.data.price_unit}
            description={course.data.short_description}
            items={course.data.included_items.slice(0, 4)}
            ctaLabel={course.data.cta_label}
            ctaHref={course.data.cta_href}
            featured={idx === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-20 md:py-section bg-navy text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="white"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots)"/>
      </svg>
    </div>

    <div class="container-page relative">
      <div class="max-w-2xl mb-14" data-anim="up">
        {data.testimonials_section_eyebrow && <p class="eyebrow text-accent-light">{data.testimonials_section_eyebrow}</p>}
        {data.testimonials_section_title && <h2 class="text-h2 text-white">{data.testimonials_section_title}</h2>}
        {data.testimonials_section_intro && <p class="text-lead text-white/80 mt-4">{data.testimonials_section_intro}</p>}
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {testimonials.map((t) => (
          <TestimonialCard
            name={t.data.name}
            quote={t.data.quote}
            rating={t.data.rating}
          />
        ))}
      </div>
    </div>
  </section>

  <ContactSection
    eyebrow={data.contact_section_eyebrow}
    title={data.contact_section_title}
    intro={data.contact_section_intro}
  />
</BaseLayout>
