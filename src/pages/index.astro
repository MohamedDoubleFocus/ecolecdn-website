---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ContactSection from '../components/ContactSection.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const page = await getEntry('pages', 'accueil');
const data = page!.data;

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={data.title} description={data.meta_description} keywords={data.meta_keywords}>
  <slot name="head" slot="head">
    <LocalBusinessSchema />
  </slot>

  <Hero
    title={data.hero_title!}
    subtitle={data.hero_subtitle}
    image={data.hero_image!}
    imageAlt="Vue conducteur sur une route à l'horizon — perspective d'apprentissage de la conduite."
    ctaLabel={data.cta_label}
    ctaHref={data.cta_href}
    secondaryLabel="Nous joindre"
    secondaryHref="#contact"
  />

  <!-- Section "École de conduite experte" -->
  <section class="py-20 md:py-section">
    <div class="container-page grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div data-anim="up">
        <p class="eyebrow">Allez plus loin avec notre école</p>
        <h2 class="text-h2 mb-6">École de conduite experte à Montréal</h2>
        <div class="space-y-5 text-ink leading-relaxed text-lg max-w-prose">
          <p>
            Forts de plus de <strong class="text-navy font-semibold">20 ans d'expérience</strong> et après avoir formé plus de <strong class="text-navy font-semibold">2 500 élèves</strong>, nos instructeurs de conduite ont acquis une réputation solide.
          </p>
          <p>
            Certifiés et dévoués, ils offrent une formation personnalisée, mettant l'accent sur la sécurité routière et la confiance au volant. Que vous soyez débutant ou souhaitiez perfectionner vos compétences, nous avons le forfait adapté à vos besoins.
          </p>
          <p>
            Rejoignez-nous pour devenir un conducteur sûr et responsable rapidement, tout en bénéficiant de nos tarifs compétitifs et de nos offres exceptionnelles.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-6 mt-10 pt-8 border-t border-slate-100">
          <div>
            <p class="font-display text-3xl font-bold text-accent">20+</p>
            <p class="text-sm text-ink-soft mt-1">Années d'expérience</p>
          </div>
          <div>
            <p class="font-display text-3xl font-bold text-accent">2500+</p>
            <p class="text-sm text-ink-soft mt-1">Élèves formés</p>
          </div>
          <div>
            <p class="font-display text-3xl font-bold text-accent">98%</p>
            <p class="text-sm text-ink-soft mt-1">Taux de réussite</p>
          </div>
        </div>
      </div>
      <div class="relative" data-anim="up">
        <img
          src="/images/image-voiture-auto-ecole-cdn.png"
          alt="Voiture-école de l'École de conduite Côte-des-Neiges en service à Montréal."
          class="w-full h-auto rounded-card shadow-lift object-cover aspect-[4/5]"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute -bottom-6 -left-6 bg-white rounded-card shadow-soft p-5 hidden md:block">
          <p class="font-display font-semibold text-navy">Certifié SAAQ</p>
          <p class="text-xs text-ink-soft">Programme PESR officiel</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section seconde : "Une école au cœur" -->
  <section class="py-20 md:py-section bg-sky-soft">
    <div class="container-page grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="lg:order-2" data-anim="up">
        <p class="eyebrow">Au cœur de Côte-des-Neiges</p>
        <h2 class="text-h2 mb-6">Flexibilité et proximité</h2>
        <div class="space-y-5 text-ink leading-relaxed text-lg max-w-prose">
          <p>
            Située à <strong class="text-navy font-semibold">Côte-des-Neiges</strong>, notre école de conduite est idéalement placée pour desservir toute la communauté environnante. Nous proposons des cours en semaine et en fin de semaine, ainsi que des leçons en ligne pour plus de flexibilité.
          </p>
          <p>
            En plus des cours de base, nous offrons des leçons de conduite avancée et une préparation complète pour le test de conduite sur circuit. Avec notre approche pédagogique innovante et notre soutien continu, chaque élève reçoit l'attention nécessaire pour réussir.
          </p>
          <p>
            Choisissez notre école pour une formation de qualité et une expérience d'apprentissage positive.
          </p>
        </div>
        <a href="/cours" class="btn-secondary mt-8">Découvrir nos formations</a>
      </div>
      <div class="lg:order-1" data-anim="up">
        <img
          src="/images/moniteur-avecetudiant-dans-voiture-montrant-la-route.png"
          alt="Moniteur expérimenté guidant un élève au volant lors d'une leçon pratique de conduite."
          class="w-full h-auto rounded-card shadow-lift object-cover aspect-[4/5]"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Cours et tarifs -->
  <section class="py-20 md:py-section">
    <div class="container-page">
      <div class="max-w-2xl mb-14" data-anim="up">
        <p class="eyebrow">Formations</p>
        <h2 class="text-h2">Nos cours et tarifs</h2>
        <p class="text-lead text-ink-soft mt-4">
          Deux formations adaptées à votre niveau et à vos objectifs : la formation
          complète PESR pour obtenir votre permis Classe 5, ou des heures de perfectionnement
          à la carte.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        {courses.map((course, idx) => (
          <CourseCard
            title={course.data.title}
            price={course.data.price}
            priceUnit={course.data.price_unit}
            description={course.data.short_description}
            items={course.data.included_items.slice(0, 4)}
            ctaLabel={course.data.cta_label}
            ctaHref={course.data.cta_href}
            featured={idx === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-20 md:py-section bg-navy text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="white"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots)"/>
      </svg>
    </div>

    <div class="container-page relative">
      <div class="max-w-2xl mb-14" data-anim="up">
        <p class="eyebrow text-accent-light">Ils nous font confiance</p>
        <h2 class="text-h2 text-white">Témoignages</h2>
        <p class="text-lead text-white/80 mt-4">
          Découvrez ce que nos élèves ont vécu chez nous.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {testimonials.map((t) => (
          <TestimonialCard
            name={t.data.name}
            quote={t.data.quote}
            rating={t.data.rating}
          />
        ))}
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
