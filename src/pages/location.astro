---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactSection from '../components/ContactSection.astro';

const page = await getEntry('pages', 'location');
const { Content } = await page!.render();
const data = page!.data;

const contact = await getEntry('contact', 'info');
const phone = contact!.data.phone;
const phoneLink = contact!.data.phone_link;
---

<BaseLayout title={data.title} description={data.meta_description} keywords={data.meta_keywords}>
  <Hero
    title={data.hero_title!}
    subtitle={data.hero_subtitle}
    image={data.hero_image!}
    imageAlt="Voiture-école effectuant un parcours avec cônes — préparation à l'examen pratique SAAQ."
    variant="compact"
    ctaLabel="Réservez maintenant"
    ctaHref={`tel:${phoneLink}`}
  />

  <section class="py-20 md:py-section">
    <div class="container-page grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="prose-content" data-anim="up">
        <p class="eyebrow">Service de location</p>
        <h2 class="text-h2">Un véhicule prêt pour votre examen</h2>
        <Content />

        <ul class="space-y-2.5 mt-6 not-prose">
          <li class="flex items-start gap-2.5"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><span>Véhicule régulièrement entretenu et inspecté</span></li>
          <li class="flex items-start gap-2.5"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><span>Transmission automatique, climatisation, banquette ajustable</span></li>
          <li class="flex items-start gap-2.5"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><span>Conforme aux exigences SAAQ pour l'examen pratique</span></li>
          <li class="flex items-start gap-2.5"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><span>Disponibilité aux centres Henri-Bourassa et Laval</span></li>
        </ul>

        <div class="mt-10 flex flex-wrap gap-3 not-prose">
          <a href={`tel:${phoneLink}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Appeler {phone}
          </a>
          <a href="/inscription" class="btn-secondary">M'inscrire en ligne</a>
        </div>
      </div>

      <div class="card-soft p-8 bg-gradient-to-br from-navy to-navy-dark text-white" data-anim="up">
        <p class="text-xs uppercase tracking-widest text-accent-light font-semibold mb-2">Tarif</p>
        <p class="font-display text-5xl font-bold mb-1">70 $</p>
        <p class="text-white/80 mb-6">par heure (plus taxes)</p>

        <div class="border-t border-white/20 pt-6 space-y-3">
          <p class="text-white/85 leading-relaxed text-sm">
            Forfaits disponibles pour combiner location de véhicule et heures de perfectionnement
            avant votre examen. N'hésitez pas à nous contacter pour un devis personnalisé.
          </p>
        </div>

        <div class="mt-8 pt-6 border-t border-white/20">
          <p class="text-xs uppercase tracking-widest text-white/60 mb-1">Réservation</p>
          <a href={`tel:${phoneLink}`} class="font-display text-2xl font-semibold hover:text-accent-light transition-colors">
            {phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
