---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PhaseCard from '../components/PhaseCard.astro';
import { inlineMd } from '../lib/markdown';

const page = await getEntry('pages', 'cours');
const data = page!.data;

const courses = await getCollection('courses');
const pesr = courses.find((c) => c.data.slug === 'pesr-classe-5')!;
const perfect = courses.find((c) => c.data.slug === 'perfectionnement')!;
---

<BaseLayout title={data.title} description={data.meta_description} keywords={data.meta_keywords}>
  <Hero
    title={data.hero_title!}
    subtitle={data.hero_subtitle}
    image={data.hero_image!}
    imageAlt="Enseignant montrant le code de la route à un élève dans une voiture-école."
    variant="compact"
    ctaLabel={data.cta_label}
    ctaHref={data.cta_href}
  />

  <!-- PESR Classe 5 -->
  <section class="py-20 md:py-section">
    <div class="container-page">
      <div class="grid lg:grid-cols-3 gap-12 mb-16">
        <div class="lg:col-span-1" data-anim="up">
          {data.pesr_eyebrow && <p class="eyebrow">{data.pesr_eyebrow}</p>}
          <h2 class="text-h2 mb-4">{pesr.data.title}</h2>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="font-display text-5xl font-bold text-accent">{pesr.data.price}</span>
            <span class="text-ink-soft text-sm">{pesr.data.price_unit}</span>
          </div>
          {data.pesr_deposit_note && (
            <p class="text-ink leading-relaxed mb-6" set:html={inlineMd(data.pesr_deposit_note)} />
          )}
          <ul class="space-y-2.5 mb-8 text-sm">
            {pesr.data.included_items.map((item: string) => (
              <li class="flex items-start gap-2.5">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/inscription" class="btn-primary text-sm py-3">Je m'inscris</a>
            <a href="#perfectionnement" class="btn-ghost">Voir aussi le perfectionnement →</a>
          </div>
        </div>

        <div class="lg:col-span-2" data-anim="up">
          {(data.pesr_program_title || data.pesr_program_description) && (
            <div class="card-soft bg-gradient-to-br from-navy to-navy-dark text-white p-8 mb-8">
              {data.pesr_program_title && <h3 class="font-display text-2xl mb-3 text-white">{data.pesr_program_title}</h3>}
              {data.pesr_program_description && <p class="text-white/85 leading-relaxed">{data.pesr_program_description}</p>}
            </div>
          )}
          <div class="grid sm:grid-cols-2 gap-6">
            {pesr.data.phases?.map((phase: { number: number; title: string; theory: string; practice?: string; duration: string }) => (
              <PhaseCard
                number={phase.number}
                title={phase.title}
                theory={phase.theory}
                practice={phase.practice}
                duration={phase.duration}
              />
            ))}
          </div>
        </div>
      </div>

      <!-- Bannière weekend / domicile -->
      <div class="grid md:grid-cols-2 gap-6 mt-12">
        {(data.pesr_weekend_title || data.pesr_weekend_text) && (
          <div class="card-soft p-7 bg-sky-soft border-0 flex items-start gap-4" data-anim="up">
            <span class="w-11 h-11 rounded-full bg-navy text-white flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <div>
              {data.pesr_weekend_title && <h3 class="font-display font-semibold text-lg mb-1">{data.pesr_weekend_title}</h3>}
              {data.pesr_weekend_text && <p class="text-ink text-sm leading-relaxed">{data.pesr_weekend_text}</p>}
            </div>
          </div>
        )}
        {(data.pesr_home_title || data.pesr_home_text) && (
          <div class="card-soft p-7 bg-sky-soft border-0 flex items-start gap-4" data-anim="up">
            <span class="w-11 h-11 rounded-full bg-accent text-white flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </span>
            <div>
              {data.pesr_home_title && <h3 class="font-display font-semibold text-lg mb-1">{data.pesr_home_title}</h3>}
              {data.pesr_home_text && <p class="text-ink text-sm leading-relaxed">{data.pesr_home_text}</p>}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Perfectionnement -->
  <section id="perfectionnement" class="py-20 md:py-section bg-sky-soft">
    <div class="container-page">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div data-anim="up">
          {data.perfect_eyebrow && <p class="eyebrow">{data.perfect_eyebrow}</p>}
          <h2 class="text-h2 mb-4">{perfect.data.title}</h2>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="font-display text-5xl font-bold text-accent">{perfect.data.price}</span>
            <span class="text-ink-soft text-base">{perfect.data.price_unit}</span>
          </div>
          <p class="text-ink leading-relaxed mb-6 text-lg max-w-prose">
            {perfect.data.short_description}
          </p>
          {data.perfect_extra_text && (
            <p class="text-ink leading-relaxed mb-6 max-w-prose" set:html={inlineMd(data.perfect_extra_text)} />
          )}
          <a href="/inscription" class="btn-primary">Je m'inscris</a>
        </div>

        <div class="card-soft p-8" data-anim="up">
          {data.perfect_included_title && <h3 class="font-display font-semibold text-xl mb-5">{data.perfect_included_title}</h3>}
          <ul class="space-y-3">
            {perfect.data.included_items.map((item: string) => (
              <li class="flex items-start gap-3 text-ink">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" class="flex-shrink-0 mt-0.5" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
